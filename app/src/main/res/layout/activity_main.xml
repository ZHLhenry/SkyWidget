<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 顶部标题栏 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FF6200EE"
        android:gravity="center"
        android:text="SkyWidget 示例"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Badge 演示区域 -->
    <LinearLayout
        android:id="@+id/badgeSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:text="Badge 角标演示"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Badge 目标1：数字角标 -->
            <FrameLayout
                android:id="@+id/badgeTarget1"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="16dp"
                android:background="#F0F0F0"
                android:foreground="@drawable/ic_nav_home"
                android:foregroundGravity="center" />

            <!-- Badge 目标2：文本角标 -->
            <FrameLayout
                android:id="@+id/badgeTarget2"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="16dp"
                android:background="#F0F0F0"
                android:foreground="@drawable/ic_nav_discover"
                android:foregroundGravity="center" />

            <!-- Badge 目标3：拖拽角标 -->
            <FrameLayout
                android:id="@+id/badgeTarget3"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="16dp"
                android:background="#F0F0F0"
                android:foreground="@drawable/ic_nav_project"
                android:foregroundGravity="center" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← 数字 | 文本 | 拖拽消除 →"
            android:textColor="#888888"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- IconFont 演示区域 -->
    <LinearLayout
        android:id="@+id/iconFontSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/badgeSection">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:text="IconFont 图标字体演示"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvIconFont"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textSize="24sp"
            tools:text="图标示例" />

        <ImageView
            android:id="@+id/ivIconFont"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            tools:src="@drawable/ic_nav_home" />
    </LinearLayout>

    <!-- 底部导航 -->
    <com.sky.widget.bottomNavigationView.SkyBottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
